{
  "entities": {
    "User": {
      "title": "User",
      "description": "Registered user profile",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "store_owner"] },
        "savedAddresses": { 
          "type": "array", 
          "items": { "type": "string" } 
        },
        "createdAt": { "type": "string" }
      },
      "required": ["email", "name", "role", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Product details",
      "type": "object",
      "properties": {
        "storeId": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string" },
        "inStock": { "type": "boolean" }
      },
      "required": ["storeId", "name", "category", "price", "inStock"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "storeId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "delivered"] },
        "deliveryAddress": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "storeId", "items", "total", "status", "deliveryAddress", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Products available across stores"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "User orders"
    }
  }
}
