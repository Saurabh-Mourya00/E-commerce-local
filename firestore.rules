rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidUser(data) {
      return data.keys().hasAny(['email', 'name', 'role', 'createdAt']) &&
             data.email is string && data.email.size() <= 200 &&
             data.name is string && data.name.size() <= 100 &&
             data.role is string && (data.role == 'customer' || data.role == 'store_owner' || data.role == 'admin');
    }

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow list: if false; // No blanket listing
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'savedAddresses']);
    }

    function isValidProduct(data) {
      return data.keys().hasAny(['storeId', 'name', 'category', 'price', 'inStock']) &&
             data.name is string && data.category is string &&
             data.price is number && data.inStock is bool;
    }

    match /products/{productId} {
      allow read: if true; // Public catalog
      allow create: if isSignedIn() && isValidProduct(incoming());
      allow update: if isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['price', 'inStock']);
    }

    function isValidOrder(data) {
      return data.keys().hasAny(['userId', 'storeId', 'items', 'total', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.status in ['pending', 'confirmed', 'delivered'] &&
             data.total is number;
    }

    match /orders/{orderId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidOrder(incoming());
      allow update: if isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['status']);
    }
  }
}
